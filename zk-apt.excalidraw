      "boundElements": [],
      "updated": 1773418258000,
      "link": null,
      "locked": false,
      "text": "P_share_recipient = zk_esk * PK_zk_recipient\nP_share_audit = zk_esk * PK_zk_aduit \n\nrecipient_mask = HASH(P_share_recipient, cipher_nonce)\naudit_mask = HASH(P_share_audit, cipher_nonce) \n\n  check:\n  ct_recipient == newSecret + recipient_mask\n  ct_audit == commitment + audit_mask ",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "P_share_recipient = zk_esk * PK_zk_recipient\nP_share_audit = zk_esk * PK_zk_aduit \n\nrecipient_mask = HASH(P_share_recipient, cipher_nonce)\naudit_mask = HASH(P_share_audit, cipher_nonce) \n\n  check:\n  ct_recipient == newSecret + recipient_mask\n  ct_audit == commitment + audit_mask ",
      "autoResize": true,
      "lineHeight": 1.25
    },
